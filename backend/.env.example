# ============================================================
# BIOMETRIC VOTING SYSTEM - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biometric_voting
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Redis (for sessions and rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_256_bit_secret_key_here_change_this_in_production
JWT_EXPIRES_IN=10m

# Biometric Encryption (AES-256 key, 32 bytes base64)
BIOMETRIC_ENCRYPTION_KEY=your_32_byte_base64_encoded_key_here

# WebAuthn / FIDO2
RP_NAME=National Voting System
RP_ID=localhost
ORIGIN=http://localhost:3000

# Admin
ADMIN_JWT_SECRET=separate_admin_jwt_secret_here
ADMIN_JWT_EXPIRES_IN=8h

# Face Recognition
FACE_MATCH_THRESHOLD=0.45

# Rate Limiting
MAX_AUTH_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
